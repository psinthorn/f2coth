# ------------------------------------------------------------------
# Vercel deployment env vars — f2-website frontend
# ------------------------------------------------------------------
# Set these in the Vercel dashboard: Project Settings → Environment Variables.
# Copy this file to `.env.local` for local Vercel-mode testing (`vercel dev`).
#
# The Go microservices continue to run on your WHM VPS behind Traefik.
# Vercel's Next.js only *calls* them over HTTPS.
#
# Vercel Project Settings:
#   Root Directory:     services/web-app
#   Framework Preset:   Next.js (auto-detected)
#   Node.js Version:    20.x or 22.x
#   Build Command:      (leave default — vercel.json handles it)
# ------------------------------------------------------------------

# --- Public API base (visible to the browser) ---
# Point at Traefik on your VPS. Must be HTTPS in production.
NEXT_PUBLIC_API_BASE=https://api.f2.co.th/api

# --- Server-side API URLs (used by Server Components / RSC) ---
# On Vercel these MUST be full HTTPS URLs — no docker hostnames like http://cms-api:8001.
# Point at the same Traefik ingress; add whatever path prefix your ingress uses.
CMS_API_URL=https://api.f2.co.th/cms-api
LEAD_API_URL=https://api.f2.co.th/lead-api
AI_CHAT_API_URL=https://api.f2.co.th/ai-chat-api
AUTH_API_URL=https://api.f2.co.th/auth-api
NOTIFICATION_API_URL=https://api.f2.co.th/notification-api

# --- JWT signing secret (only needed if any Vercel route reads JWTs) ---
# JWT_SECRET=change-me-must-match-auth-api

# --- Optional: Claude API key if any server route uses it directly ---
# ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------------
# Public-only static build (recommended for f2.co.th on Vercel)
# ------------------------------------------------------------------
# When PUBLIC_ONLY_BUILD=1 (set in vercel.json), /admin, /portal, and
# /payments routes redirect to BACKOFFICE_HOST — so Vercel only serves
# marketing pages, all statically generated at build time.
#
# Marketing pages call the CMS API at build time only; visitors never
# trigger a serverless function. Bill: essentially $0.
BACKOFFICE_HOST=https://admin.f2.co.th

# ------------------------------------------------------------------
# Traefik-side prep (do this on the VPS, once):
# ------------------------------------------------------------------
# 1. Expose each Go service behind a public HTTPS route on api.f2.co.th, e.g.
#      api.f2.co.th/cms-api/*        → cms-api:8001
#      api.f2.co.th/lead-api/*       → lead-api:8002
#      ... etc.
# 2. Restrict CORS on the Go services to https://<your-vercel-domain>
#    and https://f2.co.th once DNS cuts over.
# 3. Confirm Let's Encrypt cert is valid for api.f2.co.th.
#
# Nothing in docker-compose.yml or the Go services needs to change for
# Vercel to work — this is purely additive routing on your existing ingress.
