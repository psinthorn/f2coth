# ============================================================
# F2 Co., Ltd. — Corporate Website
# Copy this file to .env and fill in real values for local dev.
# ============================================================

# ---------- Postgres ----------
POSTGRES_USER=f2
POSTGRES_PASSWORD=f2_dev_password
POSTGRES_DB=f2_website
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://f2:f2_dev_password@postgres:5432/f2_website?sslmode=disable

# ---------- Auth ----------
# JWT_SECRET must be at least 32 characters. auth-api will refuse to start otherwise.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48
JWT_ISSUER=f2.co.th
JWT_TTL_MINUTES=60
REFRESH_TTL_HOURS=720

# AssetHub — pepper mixed into the SHA-256 hash of every collector/probe
# enrollment token (assethub-api). A DB leak alone can't forge a token without
# it. Generate with: openssl rand -base64 48
TOKEN_PEPPER=replace-with-output-of-openssl-rand-base64-48
BCRYPT_COST=12
# Base URL used in password-reset links. http://localhost for dev, https://f2.co.th for prod.
SITE_URL=http://localhost
# Symmetric key for pgcrypto encryption of smtp_settings.password. Generate with:
#   openssl rand -base64 48
# Set in staging + prod; leave empty in dev to fall back to the SMTP_PASSWORD env var.
SMTP_CRYPT_KEY=

# ---------- Claude / AI Chat ----------
# Get a key from https://console.anthropic.com/ — never commit a real key here.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# ---------- Notifications ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@f2.co.th
SMTP_PASSWORD=app-password-here
SMTP_FROM="F2 Co., Ltd. <hello@f2.co.th>"
SALES_NOTIFY_TO=sales@f2.co.th
PRIVACY_NOTIFY_TO=privacy@f2.co.th

# ---------- Service ports (host-side, dev only) ----------
WEB_APP_PORT=3000
CMS_API_PORT=8001
LEAD_API_PORT=8002
AI_CHAT_API_PORT=8003
AUTH_API_PORT=8004
NOTIFICATION_API_PORT=8005
CUSTOMER_API_PORT=8006
RESELLER_API_PORT=8007
PAYMENT_API_PORT=8008
TRAEFIK_PORT=80
TRAEFIK_DASHBOARD_PORT=8080

# ---------- Billing & PayPal (payment-api) ----------
# BILLING_NOTIFY_TO receives slip-uploaded / verification queue notifications.
BILLING_NOTIFY_TO=billing@f2.co.th
PORTAL_BASE_URL=http://localhost
ADMIN_BASE_URL=http://localhost
PUBLIC_BASE_URL=http://localhost
# Advance renewal heads-ups: "days before next_billing_at" tiers the
# scheduler emails customer + billing team. Keep above the 7-day invoice
# lead so they don't overlap the invoice email. Blank disables the pass.
RENEWAL_REMINDER_OFFSETS=30,14
# Domain renewal engine (expiry-date driven off customer_domains).
# DOMAIN_RENEWAL_NOTICE_OFFSETS: "days before expiry" customer notice tiers
#   (blank disables notices). DOMAIN_RENEWAL_INVOICE_LEAD: auto-generate the
#   renewal invoice this many days before expiry for auto_renew domains
#   (0 disables). DOMAIN_POST_EXPIRY_NOTICE_DAYS: send the "expired" notice
#   this many days after expiry (0 disables).
DOMAIN_RENEWAL_NOTICE_OFFSETS=60,30,7
DOMAIN_RENEWAL_INVOICE_LEAD=14
DOMAIN_POST_EXPIRY_NOTICE_DAYS=1

# PayPal — sandbox for dev, live for prod. With env=sandbox and credentials
# blank, payment-api will accept other methods but reject any PayPal start
# request with a clear "paypal not configured" error.
# ---------- PayPal ----------
# All PayPal credentials (sandbox + live client_id / client_secret /
# webhook_id / merchant_email) are managed from /admin/payment-methods
# and stored in payment_methods_config.config (migration 024). No env-
# side knobs. The per-method mode (sandbox|production) is a separate
# dropdown on the same admin page (migration 023).

# ---------- ResellerClub (Phase 4B) ----------
# Sandbox endpoint by default. Switch RESELLERCLUB_BASE_URL to https://httpapi.com
# for production. With auth empty, reseller-api falls back to a deterministic
# mock so dev works without real creds.
RESELLERCLUB_BASE_URL=https://test.httpapi.com
RESELLERCLUB_AUTH_USERID=
RESELLERCLUB_API_KEY=
RESELLER_OUTBOUND_TIMEOUT=8s
RESELLER_CACHE_TTL=15m

# Required for live registration (Phase 4C). With creds set but these blank,
# /api/reseller/orders/{id}/place returns a clear "set ENV_VAR_X" error.
RESELLERCLUB_DEFAULT_CUSTOMER_ID=
RESELLERCLUB_DEFAULT_CONTACT_ID=
RESELLERCLUB_DEFAULT_NS1=dns1.f2.co.th
RESELLERCLUB_DEFAULT_NS2=dns2.f2.co.th

# Registrar sync worker (Phase 3). Polls ResellerClub for authoritative
# domain expiry and reconciles customer_domains.expires_at.
#   off    — worker disabled (default; also inert without creds)
#   notify — email BILLING_NOTIFY_TO when registry expiry differs from ours,
#            but never overwrite expires_at
#   write  — update expires_at from the registry automatically
# .th domains stay manual (THNIC has no wired API). SYNC_INTERVAL is the
# poll cadence + per-domain staleness; SYNC_BATCH caps domains per tick.
RESELLER_SYNC_MODE=off
RESELLER_SYNC_INTERVAL=24h
RESELLER_SYNC_BATCH=50

# ---------- Public URLs ----------
NEXT_PUBLIC_API_BASE=http://localhost/api
NEXT_PUBLIC_SITE_URL=http://localhost
NEXT_PUBLIC_COMPANY_NAME="F2 Co., Ltd."

# ---------- CORS ----------
# Comma-separated allowlist of origins permitted to call our APIs.
# DO NOT use "*" in production — auth-api will print a warning on startup if you do.
# Production should be: CORS_ALLOWED_ORIGINS=https://f2.co.th
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://f2.co.th

# ---------- Deploy (staging + prod overlays only) ----------
# These are consumed by docker-compose.prod.yml / docker-compose.staging.yml.
# The GitHub Actions deploy job overwrites IMAGE_TAG on every run.
DOMAIN=f2.co.th                 # or staging.f2.co.th on the staging box
ACME_EMAIL=info@f2.co.th        # Let's Encrypt registration email
GHCR_OWNER=f2coltd              # GitHub owner that owns ghcr.io/<owner>/f2-*
IMAGE_TAG=latest                # git sha in CI-driven deploys

# ---------- Cloudflare (in front of the VPS) ----------
# No secrets here — Traefik already trusts the public CF IP ranges in
# docker-compose.prod.yml. The two things you interact with are:
#   • scripts/refresh-cloudflare-ips.sh  — rewrites the trusted IP list
#   • scripts/firewall-cloudflare-only.sh — locks host :443 to CF ranges
# See docs/cloudflare-setup.md for the dashboard configuration steps.
